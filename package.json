  "scripts": {
    "dev": "NODE_ENV=development node_modules/.bin/tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --sourcemap --outfile=dist/index.mjs && node -e \"require('fs').writeFileSync('dist/index.cjs', \\\"import('./index.mjs');\\n\\\")\"",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
