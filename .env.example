# --- Aplicação ---
NODE_ENV=development
PORT=5000

# --- Banco de dados (PostgreSQL) ---
# String de conexão completa. Em produção, use SSL.
# Ex.: postgres://user:pass@host:5432/dbname
DATABASE_URL=postgres://user:password@localhost:5432/okr_dev

# Conteúdo PEM da CA do banco (opcional). Necessário em alguns provedores
# que exigem verificação completa do certificado (ex.: Hostinger gerenciado).
# PG_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Aceitar certificados sem validar a cadeia. Use "false" apenas em produção
# quando souber o que está fazendo. Default: true
# PG_SSL_REJECT_UNAUTHORIZED=true

# --- Segurança ---
# Obrigatório em produção. Gere com: openssl rand -base64 48
# Mínimo de 32 caracteres.
SESSION_SECRET=troque-este-valor-por-uma-string-aleatoria-de-pelo-menos-32-chars
