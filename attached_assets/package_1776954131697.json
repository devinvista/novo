{
  "name": "fisiogest-pro",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build:libs": "tsc --build lib/shared-constants/tsconfig.json lib/db/tsconfig.json lib/api-zod/tsconfig.json lib/api-client-react/tsconfig.json",
    "dev": "pnpm run build:libs && (PORT=8080 pnpm --filter @workspace/api-server run dev & PORT=20408 API_PORT=8080 pnpm --filter @workspace/fisiogest run dev)",
    "build": "pnpm run build:libs && pnpm --filter @workspace/fisiogest run build && pnpm --filter @workspace/api-server run build",
    "start": "NODE_ENV=production node artifacts/api-server/dist/index.cjs",
    "db:push": "drizzle-kit push --config lib/db/drizzle.config.ts",
    "db:push-force": "drizzle-kit push --force --config lib/db/drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config lib/db/drizzle.config.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:baseline": "tsx scripts/migrate.ts -- --baseline",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed-demo": "tsx scripts/seed-demo.ts",
    "db:seed-financial": "tsx scripts/seed-financial.ts",
    "typecheck": "pnpm run build:libs && tsc --noEmit -p artifacts/fisiogest/tsconfig.json && tsc --noEmit -p artifacts/api-server/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ],
    "overrides": {
      "esbuild": "0.27.3",
      "esbuild>@esbuild/aix-ppc64": "-",
      "esbuild>@esbuild/android-arm": "-",
      "esbuild>@esbuild/android-arm64": "-",
      "esbuild>@esbuild/android-x64": "-",
      "esbuild>@esbuild/darwin-arm64": "-",
      "esbuild>@esbuild/darwin-x64": "-",
      "esbuild>@esbuild/freebsd-arm64": "-",
      "esbuild>@esbuild/freebsd-x64": "-",
      "esbuild>@esbuild/linux-arm": "-",
      "esbuild>@esbuild/linux-arm64": "-",
      "esbuild>@esbuild/linux-ia32": "-",
      "esbuild>@esbuild/linux-loong64": "-",
      "esbuild>@esbuild/linux-mips64el": "-",
      "esbuild>@esbuild/linux-ppc64": "-",
      "esbuild>@esbuild/linux-riscv64": "-",
      "esbuild>@esbuild/linux-s390x": "-",
      "esbuild>@esbuild/netbsd-x64": "-",
      "esbuild>@esbuild/openbsd-x64": "-",
      "esbuild>@esbuild/sunos-x64": "-",
      "esbuild>@esbuild/win32-arm64": "-",
      "esbuild>@esbuild/win32-ia32": "-",
      "esbuild>@esbuild/win32-x64": "-"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.99.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "embla-carousel-react": "^8.6.0",
    "esbuild": "0.27.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "framer-motion": "^12.38.0",
    "globals": "^17.5.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "prettier": "^3.8.3",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.73.1",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^2.1.9",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vaul": "^1.1.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "wouter": "^3.9.0"
  }
}
